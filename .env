# --- AI SERVICES ---
GOOGLE_API_KEY=
GROQ_API_KEY=
# OpenAI is the primary choice for LLM (GPT-4) and Transcription (Whisper)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: If using Deepgram instead of Whisper
DEEPGRAM_API_KEY=your_deepgram_key_here 
# Alternative LLM providers
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# --- TRANSCRIPTION (Optional) ---
# Set this if you prefer Deepgram over OpenAI Whisper
DEEPGRAM_API_KEY=your_deepgram_key_here

# --- VECTOR DATABASE ---
# Needed for semantic search and RAG (Retrieval Augmented Generation)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENVIRONMENT=your_pinecone_env
PINECONE_INDEX_NAME=aidocgen-index

# Neon database
DATABASE_URL=
# --- METADATA DATABASE ---
# Your Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@endpoint/dbname

# --- FILE STORAGE (For playing video/audio) ---
# If using local storage, define the path
# --- APP CONFIGURATION ---
# Directory where uploaded PDF/Video/Audio files will be stored temporarily
UPLOAD_DIR=./uploads



# Frontend
# API configuration for Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000


PORT=8000